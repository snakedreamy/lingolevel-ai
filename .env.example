# lingolevel-ai configuration
# Copy this file to .env.local and fill in real values.

# ⚠ API Keys live ONLY in this file (or your real env). They are NEVER
# sent to the browser. The browser can echo Provider/Base URL/Model
# names via /api/server-config, but the ServerConfig response is
# verified to NOT contain an apiKey field.

# === Provider selection ===
# Which protocol to use. One of: openai | anthropic
PROVIDER="openai"

# === OpenAI-compatible ===
# Works with OpenAI official, Groq, DeepSeek, OpenRouter, 硅基流动,
# self-hosted vLLM, Ollama (http://localhost:11434/v1), etc.
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_CHAT_MODEL="your-openai-compatible-chat-model"
OPENAI_ANALYZE_MODEL="your-openai-compatible-analyze-model"

# === Anthropic ===
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_CHAT_MODEL="claude-3-5-sonnet-20241022"
ANTHROPIC_ANALYZE_MODEL="claude-3-5-sonnet-20241022"

# === Server port ===
# Defaults to 59100. Set in .env.local to use a different port.
PORT="59100"

# === Common ===
# Outbound HTTP request timeout in milliseconds.
# Legal range: 1000 (1s) – 600000 (10min). Default 30000 (30s).
# Lower values fail fast on stalled upstream; higher values allow
# longer-running chat/analysis requests to complete.
REQUEST_TIMEOUT_MS="30000"

# === App URL (used for self-referential links, OAuth callbacks) ===
# Match this to the port you set in PORT above.
APP_URL="http://localhost:59100"
